# Backend API base URL. Change this when you deploy the backend somewhere
# other than localhost.
VITE_API_URL=http://localhost:5000/api

# Shop's WhatsApp number, digits only, with country code, no + or spaces.
# Used for the "Send Order to WhatsApp" button and the floating chat button.
# Keep this in sync with SHOP_WHATSAPP_NUMBER in the backend .env.
VITE_SHOP_WHATSAPP_NUMBER=916380768419
