# ── Email Notifications (Gmail via Nodemailer) ────────────────────────────────
# EMAIL_USER must be a full Gmail address. EMAIL_PASS must be a 16-character
# Gmail "App Password" — NOT your normal Gmail password. Generate one at:
# myaccount.google.com → Security → 2-Step Verification (turn on first)
#   → App passwords → create one named e.g. "Meenakshi Sarees Backend"
EMAIL_USER=youraddress@gmail.com
EMAIL_PASS=your-16-character-app-password

# Where order notifications are sent for the store owner to see.
# Can be the same as EMAIL_USER, or a different inbox you check.
STORE_EMAIL=owner@example.com

